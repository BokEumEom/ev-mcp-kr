# data.go.kr issued service key, URL-encoded form preferred (the value as-issued).
# Required.
SERVICE_KEY=

# Optional: VWorld geocoder for address → coordinates in find_chargers_nearby.
# Get a key at https://www.vworld.kr/dev/v4dv_apikey_s001.do (free, KR govt).
VWORLD_KEY=

# Server bind. Local development uses 127.0.0.1.
# Containerized deployment (Render, Docker) overrides HOST=0.0.0.0.
HOST=127.0.0.1
PORT=8000
LOG_LEVEL=INFO

# Cache TTLs (seconds)
STATION_INFO_TTL=86400
STATUS_TTL=60

# CORS allowlist (comma-separated)
CORS_ORIGINS=https://claude.ai,https://claude.com,http://localhost:6274

# Phase 10 — DuckDB analytics sidecar (ADR-001).
# Default 'local' reads scratch/chargers_snapshot.parquet (PoC artifact).
# Switch to 'r2' once Stage 10.1 publishes daily snapshots to Cloudflare R2.
SNAPSHOT_SOURCE=local
SNAPSHOT_PATH=scratch/chargers_snapshot.parquet

# Cloudflare R2 credentials (Stage 10.1+). Leave blank until the bucket exists.
# Create via:  wrangler r2 bucket create ev-mcp-snapshots
# Credentials: Cloudflare dashboard → R2 → Manage API Tokens
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
